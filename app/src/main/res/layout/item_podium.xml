<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <!-- Light/Glow behind the badge -->
        <View
            android:id="@+id/viewRankGlow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignBottom="@id/ivAvatarPodium"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="-12dp"
            android:background="@drawable/avatar_placeholder"
            android:backgroundTint="@color/accentAmber"
            android:alpha="0.3"
            app:tint="@color/accentAmber" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAvatarPodium"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:padding="4dp"
            android:src="@drawable/avatar_placeholder"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="3dp"
            app:tint="@color/white" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRankBadge"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignBottom="@id/ivAvatarPodium"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="-6dp"
            app:cardBackgroundColor="@color/accentAmber"
            app:cardCornerRadius="14dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/tvRankBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvPlayerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Explorer"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxWidth="80dp"
        android:ellipsize="end"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvPlayerScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="1000 Pts"
        android:textColor="@color/accentAmber"
        android:textSize="12sp"
        android:textStyle="bold" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPodiumStep"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="6dp"
        app:cardBackgroundColor="#26FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <View
            android:id="@+id/viewStepTopColor"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="@color/accentAmber" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>